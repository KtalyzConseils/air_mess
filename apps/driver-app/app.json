{
  "expo": {
    "name": "Driver",
    "slug": "driver-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "airmess",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1614",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.anonymous.driverapp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A1614",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 340,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Air Mess utilise votre position pour vous proposer les courses les plus proches et permettre aux clients de vous suivre.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-secure-store",
      "expo-audio",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/new_course.wav",
            "./assets/sounds/new_course_ring.wav"
          ]
        }
      ],
      "expo-image",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "RMess accède à vos photos pour envoyer vos documents d'inscription.",
          "cameraPermission": "RMess accède à l'appareil photo pour photographier vos documents d'inscription."
        }
      ],
      "./plugins/withFullScreenNotifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1c6a9410-c142-4f03-9cae-d59594b6542d"
      }
    },
    "owner": "ktalyzconseils"
  }
}
