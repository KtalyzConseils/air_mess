# Dépendances et artefacts régénérés dans l'image
/vendor
/node_modules

# Secrets et bases locales (les vars sont fournies par Railway)
.env
.env.*
!.env.example
*.sqlite
database/database.sqlite

# Données runtime (fournies par le Volume Railway monté sur /var/www/html/storage)
/storage/app/private/*
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

