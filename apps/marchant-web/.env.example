# API Air Mess (Laravel)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Firebase — Phone Auth (OTP à l'inscription driver)
# NB : ces valeurs ne sont pas des secrets techniques (Firebase apiKey est
# publique par design), mais on les sort du code pour éviter les faux
# positifs des scanners de secrets et éviter d'exposer la config en clair
# dans le git history. Les vraies valeurs viennent de Firebase Console →
# Project settings → Your apps → Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
